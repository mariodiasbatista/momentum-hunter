# Alpaca API credentials
# Get these at https://app.alpaca.markets (paper or live)
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
# Use https://paper-api.alpaca.markets for paper, https://api.alpaca.markets for live
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Telegram bot
# Create a bot via @BotFather and get its token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Chat ID of the target chat or channel (use @channelusername or numeric ID)
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
